.result-hero {
  background: #3556f5;
  padding: 26rpx 28rpx 88rpx;
  color: #ffffff;
}
.top-title {
  text-align: center;
  font-size: 28rpx;
  opacity: 0.94;
  margin-bottom: 22rpx;
}
.result-card {
  background: #ffffff;
  border-radius: 26rpx;
  padding: 30rpx 24rpx;
  text-align: center;
  color: #1f2937;
  box-shadow: 0 12rpx 35rpx rgba(31, 41, 55, 0.12);
}
.status-icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  font-size: 46rpx;
  font-weight: 900;
}
.status-icon.positive { background: #ffe5e5; color: #e64545; }
.status-icon.negative { background: #dbf8ee; color: #15b985; }
.status-icon.review { background: #fff3d8; color: #f59e0b; }
.status-icon.abnormal { background: #ffe5e5; color: #ef4444; }
.status-text {
  font-size: 42rpx;
  font-weight: 900;
}
.status-text.positive { color: #e64545; }
.status-text.negative { color: #15b985; }
.status-text.review { color: #f59e0b; }
.status-text.abnormal { color: #ef4444; }
.status-sub {
  margin-top: 10rpx;
  color: #7b8497;
  font-size: 24rpx;
}
.result-wrap {
  margin-top: -64rpx;
}
.info-line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 15rpx 0;
  font-size: 26rpx;
  border-bottom: 1rpx solid #f0f2f6;
}
.info-line:last-child { border-bottom: 0; }
.label {
  color: #7b8497;
  flex-shrink: 0;
}
.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.summary-item {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 22rpx 8rpx;
  text-align: center;
  box-shadow: 0 12rpx 35rpx rgba(31, 41, 55, 0.07);
}
.num {
  font-size: 38rpx;
  font-weight: 900;
}
.name {
  margin-top: 6rpx;
  color: #7b8497;
  font-size: 22rpx;
}
.positive { color: #e64545; }
.negative { color: #15b985; }
.review { color: #f59e0b; }
.abnormal { color: #ef4444; }
.action-card button {
    width: 100%;
    display: block;
    margin-bottom: 18rpx;
    height: 88rpx;
    line-height: 88rpx;
    padding: 0 24rpx;
    box-sizing: border-box;
    text-align: center;
    font-size: 30rpx;
  }
  
  .action-card button:last-child {
    margin-bottom: 0;
  }
.section-title {
  font-size: 30rpx;
  font-weight: 850;
  margin-bottom: 14rpx;
}
.well-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f2f6;
}
.well-row:last-child { border-bottom: 0; }
.well-name {
  font-size: 27rpx;
  font-weight: 800;
}
.well-reason {
  margin-top: 6rpx;
  color: #8a93a6;
  font-size: 21rpx;
  max-width: 500rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.well-result {
  font-size: 27rpx;
  font-weight: 900;
  flex-shrink: 0;
}
.note {
  margin: 8rpx 8rpx 38rpx;
  color: #8a93a6;
  font-size: 22rpx;
  line-height: 1.7;
}
